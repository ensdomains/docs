{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ens-docs",
  "main": "./dist/server/index.js",
  "compatibility_date": "2026-07-16",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist/public",
    "binding": "ASSETS",
    "html_handling": "auto-trailing-slash",
  },
  "observability": {
    "enabled": true,
  },
}
